{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Youkeo Website (static)",
      "runtimeExecutable": "/usr/local/bin/node",
      "runtimeArgs": ["-e", "require('http').createServer((req,res)=>{const fs=require('fs'),path=require('path');let f=path.join('/Users/nishchaybeharam/Desktop/youkeo-website-final',req.url==='/'?'/index.html':req.url);fs.readFile(f,(e,d)=>{if(e){res.writeHead(404);res.end();}else{const ext=path.extname(f);const ct={'html':'text/html','css':'text/css','js':'application/javascript','mp4':'video/mp4','jpg':'image/jpeg','png':'image/png','svg':'image/svg+xml'}[ext.slice(1)]||'text/plain';res.writeHead(200,{'Content-Type':ct});res.end(d);}});}).listen(3000,()=>console.log('Listening on 3000'))"],
      "port": 3000
    }
  ]
}
